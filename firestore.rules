
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'admin@riverph.com' || 
        request.auth.token.admin == true
      );
    }

    // --- GLOBAL RULES ---

    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // --- USER PROFILES & DIRECTORY ---

    match /users/{allPaths=**} {
      // Unrestricted access for all signed-in members to facilitate collaboration and presence
      allow read, write: if isAuthenticated();
    }
    
    // --- INVITATIONS & ONBOARDING ---

    match /unclaimedProfiles/{allPaths=**} {
      allow read, write: if isAuthenticated();
    }

    match /unclaimedEmployees/{allPaths=**} {
      allow read, write: if isAuthenticated();
    }

    // --- HR MULTI-TENANT DATA ---

    match /hr_companies/{allPaths=**} {
      allow read, write: if isAuthenticated();
    }

    // --- COLLABORATION PLATFORM ---

    match /collaboration_pages/{allPaths=**} {
      // UNRESTRICTED COLLABORATION: Any signed-in user can create, edit, organize or delete any page
      // Use broad recursive match to avoid permission issues on nested structures like 'presence'
      allow read, write: if isAuthenticated();
    }
    
    match /collaboration_workspaces/{allPaths=**} {
        allow read, write: if isAuthenticated();
    }

    // --- STATION & COMPLIANCE ---

    match /waterStations/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /publicSanitationLinks/{linkId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
  }
}
