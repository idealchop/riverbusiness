
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'admin@riverph.com' || 
        request.auth.token.admin == true
      );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // --- GLOBAL RULES ---

    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // --- USER PROFILES & DIRECTORY ---

    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }
    
    match /users/{allPaths=**} {
      allow read: if isAuthenticated();
    }
    
    // --- CLOUD STORAGE APP (FILES & FOLDERS) ---

    match /cloud_files/{fileId} {
      // Users can manage their own company's files
      allow read, write: if isAuthenticated() && (
        resource == null || 
        resource.data.companyId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId
      );
    }

    match /cloud_folders/{folderId} {
      allow read, write: if isAuthenticated() && (
        resource == null || 
        resource.data.companyId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId
      );
    }

    // --- INVITATIONS & ONBOARDING ---

    match /unclaimedProfiles/{allPaths=**} {
      allow read, write: if isAuthenticated();
    }

    match /unclaimedEmployees/{allPaths=**} {
      allow read, write: if isAuthenticated();
    }

    // --- HR MULTI-TENANT DATA ---

    match /hr_companies/{allPaths=**} {
      allow read, write: if isAuthenticated();
    }

    // --- COLLABORATION PLATFORM ---

    match /collaboration_pages/{allPaths=**} {
      allow read, write: if isAuthenticated();
    }
    
    match /collaboration_workspaces/{allPaths=**} {
        allow read, write: if isAuthenticated();
    }

    // --- STATION & COMPLIANCE ---

    match /waterStations/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /publicSanitationLinks/{linkId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
  }
}
