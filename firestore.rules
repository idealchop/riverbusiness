rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAdmin() {
      // Deployed Cloud Functions run with admin privileges, so their auth object is null.
      // This rule also allows the designated admin email to act as an admin.
      return request.auth == null || (request.auth != null && request.auth.token.email == 'admin@riverph.com');
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isOrgManager() {
        let role = getUserData().hrRole;
        return request.auth != null && (role == 'owner' || role == 'admin');
    }

    function belongsToCompany(companyId) {
        return request.auth != null && getUserData().companyId == companyId;
    }

    // Admins have global read/write access to all documents for management purposes.
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    match /users/{userId} {
      allow get: if true;
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isOwner(userId) || isAdmin();
      allow create: if request.auth != null;
      allow list, read: if isOwner(userId) || isAdmin() || 
                       (request.auth != null && resource.data.parentId == request.auth.uid) ||
                       (request.auth != null && request.query.where.get('parentId')[2] == request.auth.uid) ||
                       (request.auth != null && belongsToCompany(resource.data.companyId));
    }
    
    match /unclaimedProfiles/{clientId} {
      allow read, delete: if request.auth != null;
    }

    match /unclaimedEmployees/{inviteId} {
      allow read, delete: if request.auth != null;
      // Allow Org Managers (Owners/Admins) to create invitations for their team
      allow create: if request.auth != null && (isAdmin() || isOrgManager());
      allow list: if isAdmin() || (request.auth != null && request.query.where.get('email')[2] == request.auth.token.email);
    }

    // Rules for HR-specific multi-tenant data
    match /hr_companies/{companyId} {
      allow read: if isAdmin() || belongsToCompany(companyId);
      
      match /attendance/{logId} {
        allow read, list: if isAdmin() || belongsToCompany(companyId);
        allow create: if request.auth != null && belongsToCompany(companyId);
        allow update: if isAdmin() || isOrgManager() && belongsToCompany(companyId);
      }

      match /leaveRequests/{requestId} {
        allow read, list: if isAdmin() || belongsToCompany(companyId);
        allow create: if request.auth != null && belongsToCompany(companyId);
        allow update: if isAdmin() || (isOrgManager() && belongsToCompany(companyId));
      }

      match /payrollRuns/{runId} {
        // Payroll is highly sensitive - restrict to Managers only
        allow read, list, create: if isAdmin() || (isOrgManager() && belongsToCompany(companyId));
      }
    }

    match /waterStations/{stationId} {
      allow read: if request.auth != null;
      match /{document=**} {
          allow read, list: if request.auth != null;
      }
    }

    match /publicSanitationLinks/{linkId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Allow the document owner OR an admin to perform any action on user subcollections.
     match /users/{userId}/{subcollection}/{docId} {
      allow read, write, create, update, delete: if isOwner(userId) || isAdmin();
    }
  }
}