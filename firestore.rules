
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'admin@riverph.com' || 
        request.auth.token.admin == true
      );
    }

    // --- GLOBAL RULES ---

    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // --- USER PROFILES & DIRECTORY ---

    match /users/{userId} {
      allow read, list, create, update, delete: if isAuthenticated();
      match /{subcollection}/{docId} {
        allow read, write: if isAuthenticated();
      }
    }

    // --- COLLABORATION PLATFORM ---

    match /collaboration_workspaces/{workspaceId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /collaboration_pages/{pageId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    
    // --- HR MULTI-TENANT DATA ---

    match /hr_companies/{companyId} {
      allow read, write, delete: if isAuthenticated();
      match /{allSubcollections=**} {
        allow read, write, delete: if isAuthenticated();
      }
    }

    // --- STATION & COMPLIANCE ---

    match /waterStations/{stationId} {
      allow read: if isAuthenticated();
      match /{document=**} {
          allow read, list: if isAuthenticated();
          allow write: if isAdmin();
      }
    }

    match /publicSanitationLinks/{linkId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /users/{userId}/sanitationVisits/{visitId} {
      allow read: if true;
      allow update: if true;
    }
  }
}
