rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    // Checks if the user is accessing their own document
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Platform-wide administrator check (By email or custom claim)
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'admin@riverph.com' || 
        request.auth.token.admin == true
      );
    }

    // Fetches the current user's profile data from Firestore
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // HR Management: Checks if the user is a Manager (Owner or Admin) for their company
    function isOrgManager() {
        let role = getUserData().hrRole;
        return request.auth != null && (role == 'owner' || role == 'admin');
    }

    // Multi-Tenancy: Validates that the user belongs to the company they are accessing
    function belongsToCompany(companyId) {
        return request.auth != null && getUserData().companyId == companyId;
    }

    // --- GLOBAL RULES ---

    // Admins have master access to all resources
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // --- USER PROFILES ---

    match /users/{userId} {
      // Profiles are publicly checkable for 'get' (e.g. for invitations) but 'list' is restricted
      allow get: if true;
      allow create: if request.auth != null;
      allow update, delete: if isOwner(userId) || isAdmin();
      
      // Multi-Branch Visibility: Parents can see their branches; Managers can see their team
      allow list, read: if isOwner(userId) || isAdmin() || 
                       (request.auth != null && resource.data.parentId == request.auth.uid) ||
                       (request.auth != null && belongsToCompany(resource.data.companyId));

      // Sub-collections (Deliveries, Payments, Notifications)
      match /{subcollection}/{docId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      
      // Branch-specific deliveries allow parents to read logs
      match /branchDeliveries/{deliveryId} {
          allow read: if isOwner(userId) || isAdmin();
      }
    }
    
    // --- INVITIATIONS ---

    match /unclaimedProfiles/{clientId} {
      allow read, delete: if request.auth != null;
    }

    match /unclaimedEmployees/{inviteId} {
      allow read, delete: if request.auth != null;
      allow create: if isAdmin() || isOrgManager();
      allow list: if isAdmin() || (request.auth != null && request.query.where.get('email')[2] == request.auth.token.email);
    }

    // --- HR MULTI-TENANT DATA ---

    match /hr_companies/{companyId} {
      allow read: if isAdmin() || belongsToCompany(companyId);
      
      // Attendance: Employees can create their own; Managers can review/update
      match /attendance/{logId} {
        allow read, list: if isAdmin() || belongsToCompany(companyId);
        allow create: if request.auth != null && belongsToCompany(companyId);
        allow update: if isAdmin() || (isOrgManager() && belongsToCompany(companyId));
      }

      // Leaves: Employees can apply; Managers can approve/reject
      match /leaveRequests/{requestId} {
        allow read, list: if isAdmin() || belongsToCompany(companyId);
        allow create: if request.auth != null && belongsToCompany(companyId);
        allow update: if isAdmin() || (isOrgManager() && belongsToCompany(companyId));
      }

      // Payroll: Restricted exclusively to Managers
      match /payrollRuns/{runId} {
        allow read, list, create: if isAdmin() || (isOrgManager() && belongsToCompany(companyId));
      }
    }

    // --- STATION & COMPLIANCE ---

    match /waterStations/{stationId} {
      allow read: if request.auth != null;
      match /{document=**} {
          allow read, list: if request.auth != null;
      }
    }

    // Public links for mobile sanitation officers (Limited write to status/checklist)
    match /publicSanitationLinks/{linkId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId}/sanitationVisits/{visitId} {
      allow read: if true; // Allows the public link page to show report details
      allow update: if (request.auth == null) && request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['dispenserReports', 'status', 'officerSignature', 'clientSignature', 'clientRepName', 'officerSignatureDate', 'clientSignatureDate']);
    }
  }
}