
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    // Checks if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Platform-wide administrator check (By email or custom claim)
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'admin@riverph.com' || 
        request.auth.token.admin == true
      );
    }

    // --- GLOBAL RULES ---

    // Admins have master access to all resources
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // --- USER PROFILES & DIRECTORY ---

    match /users/{allPaths=**} {
      // Radical transparency: any signed-in user can manage profiles for presence and attribution
      allow read, write: if isAuthenticated();
    }
    
    // --- INVITATIONS & ONBOARDING ---

    match /unclaimedProfiles/{allPaths=**} {
      allow read, write: if isAuthenticated();
    }

    match /unclaimedEmployees/{allPaths=**} {
      allow read, write: if isAuthenticated();
    }

    // --- HR MULTI-TENANT DATA ---

    match /hr_companies/{allPaths=**} {
      // Open access for all authenticated organization members
      allow read, write: if isAuthenticated();
    }

    // --- COLLABORATION PLATFORM ---

    match /collaboration_pages/{allPaths=**} {
      // UNRESTRICTED COLLABORATION: Any signed-in user can create, edit, organize or delete any page
      allow read, write: if isAuthenticated();
    }
    
    match /collaboration_workspaces/{allPaths=**} {
        allow read, write: if isAuthenticated();
    }

    // --- STATION & COMPLIANCE ---

    match /waterStations/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Public links for mobile sanitation officers
    match /publicSanitationLinks/{linkId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /users/{userId}/sanitationVisits/{visitId} {
      allow read: if true;
      allow update: if true;
    }
  }
}
