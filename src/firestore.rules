
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    // Checks if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Platform-wide administrator check (By email or custom claim)
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'admin@riverph.com' || 
        request.auth.token.admin == true
      );
    }

    // --- GLOBAL RULES ---

    // Admins have master access to all resources
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // --- USER PROFILES & DIRECTORY ---

    match /users/{userId} {
      // Radical transparency for organizational collaboration: 
      // All authenticated users can read, list, and update profiles (for presence and attribution)
      allow read, list, create, update, delete: if isAuthenticated();

      match /{allSubcollections=**} {
        allow read, write: if isAuthenticated();
      }
    }
    
    // --- INVITATIONS & ONBOARDING ---

    match /unclaimedProfiles/{clientId} {
      allow read, write: if isAuthenticated();
    }

    match /unclaimedEmployees/{inviteId} {
      allow read, write: if isAuthenticated();
    }

    // --- HR MULTI-TENANT DATA ---

    match /hr_companies/{companyId} {
      // Open access for all authenticated organization members
      allow read, write, delete: if isAuthenticated();
      
      match /{allSubcollections=**} {
        allow read, write, delete: if isAuthenticated();
      }
    }

    // --- COLLABORATION PLATFORM ---

    match /collaboration_workspaces/{workspaceId} {
      allow read, write: if isAuthenticated();
    }

    match /collaboration_pages/{pageId} {
      // UNRESTRICTED COLLABORATION: Any signed-in user can create, edit, or delete pages
      allow read, write: if isAuthenticated();
      
      // Recursive match for presence and other potential sub-data
      match /{allSubcollections=**} {
        allow read, write: if isAuthenticated();
      }
    }

    // --- STATION & COMPLIANCE ---

    match /waterStations/{stationId} {
      allow read: if isAuthenticated();
      match /{document=**} {
          allow read, list: if isAuthenticated();
          allow write: if isAdmin();
      }
    }

    // Public links for mobile sanitation officers
    match /publicSanitationLinks/{linkId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /users/{userId}/sanitationVisits/{visitId} {
      allow read: if true;
      allow update: if true;
    }
  }
}
