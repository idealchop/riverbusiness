
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'admin@riverph.com' || 
        request.auth.token.admin == true
      );
    }
    
    function isSameCompany(companyId) {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId == companyId ||
        isAdmin()
      );
    }
    
    function isPublicPage(pageData) {
      return pageData.isPublic == true && 
             (pageData.expiresAt == null || pageData.expiresAt > request.time);
    }

    // --- GLOBAL RULES ---

    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // --- USER PROFILES & DIRECTORY ---

    match /users/{userId} {
      // Users can see their own profile or profiles of people in their same company
      allow read: if isAuthenticated() && (
        request.auth.uid == userId || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId == resource.data.companyId ||
        isAdmin()
      );
      // Users can only edit their own profile
      allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      
      // Allow collection queries for users within the same company
      match /{allSubcollections=**} {
         allow read, write: if isAuthenticated() && (
            request.auth.uid == userId || 
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId == get(/databases/$(database)/documents/users/$(userId)).data.companyId ||
            isAdmin()
         );
      }
    }
    
    // --- CLOUD STORAGE APP (SHARED DRIVE) ---

    match /cloud_files/{fileId} {
      allow read, write: if isAuthenticated() && isSameCompany(resource.data.companyId);
      allow create: if isAuthenticated() && isSameCompany(request.resource.data.companyId);
    }

    match /cloud_folders/{folderId} {
      allow read, write: if isAuthenticated() && isSameCompany(resource.data.companyId);
      allow create: if isAuthenticated() && isSameCompany(request.resource.data.companyId);
    }

    // --- HR MULTI-TENANT DATA ---

    match /hr_companies/{companyId}/{document=**} {
      allow read, write: if isAuthenticated() && isSameCompany(companyId);
    }

    // --- COLLABORATION PLATFORM ---

    match /collaboration_pages/{pageId} {
      // INTERNAL ACCESS: Filtered by companyId on the resource
      allow read, write: if isAuthenticated() && (isSameCompany(resource.data.companyId) || isSameCompany(request.resource.data.companyId));
      
      // PUBLIC ACCESS: Limited read for unauthenticated users if page is public and not expired
      allow get: if isPublicPage(resource.data);
    }
    
    // Allow collection group query for public pages by shareToken
    match /{path=**}/collaboration_pages/{pageId} {
        allow list: if isPublicPage(resource.data);
    }
    
    match /collaboration_pages/{pageId}/presence/{userId} {
        allow read, write: if isAuthenticated();
    }
    
    match /collaboration_workspaces/{document=**} {
        allow read, write: if isAuthenticated();
    }

    // --- STATION & COMPLIANCE ---

    match /waterStations/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /publicSanitationLinks/{linkId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    // --- INVITATIONS & UNCLAIMED ---
    match /unclaimedEmployees/{inviteId} {
        allow read, write: if isAuthenticated();
    }
    
    match /unclaimedProfiles/{clientId} {
        allow read, write: if isAuthenticated();
    }
  }
}
