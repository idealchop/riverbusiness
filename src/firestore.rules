rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAdmin() {
      // Deployed Cloud Functions run with admin privileges, so their auth object is null.
      // This rule also allows the designated admin email to act as an admin.
      return request.auth == null || (request.auth != null && request.auth.token.email == 'admin@riverph.com');
    }

    // Admins have global read/write access to all documents for management purposes.
    // This rule is essential for Cloud Functions running with admin privileges.
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    match /users/{userId} {
      allow get: if true;
      
      // Allow the owner or an admin to update any field in the user profile.
      allow update: if isOwner(userId) || isAdmin();

      allow delete: if isOwner(userId) || isAdmin();
      
      allow create: if request.auth != null;

      allow list, read: if isOwner(userId) || isAdmin() || 
                       (request.auth != null && resource.data.parentId == request.auth.uid) ||
                       (request.auth != null && request.query.where.get('parentId')[2] == request.auth.uid);
    }
    
    match /users/{userId}/transactions/{transactionId} {
      allow read, list: if isOwner(userId) || isAdmin();
    }
    
    match /users/{userId}/chatMessages/{messageId} {
        allow read, write: if isOwner(userId) || isAdmin();
    }
    
    match /unclaimedProfiles/{clientId} {
      allow read, delete: if request.auth != null;
    }

    match /unclaimedEmployees/{inviteId} {
      allow read, delete: if request.auth != null;
      allow create: if isAdmin();
      allow list: if request.auth != null && request.query.where.get('email')[2] == request.auth.token.email;
    }

    match /waterStations/{stationId} {
      allow read: if request.auth != null;
    }
    match /waterStations/{stationId}/{document=**} {
        allow read, list: if request.auth != null;
    }
    match /schedules/currentSchedule {
      allow read: if request.auth != null;
    }

    match /{path=**}/payments/{paymentId} {
      allow list: if isAdmin();
    }
    match /{path=**}/refillRequests/{requestId} {
      allow list: if isAdmin();
    }

    match /publicSanitationLinks/{linkId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId}/sanitationVisits/{visitId} {
      allow write, delete: if isOwner(userId) || isAdmin();
      allow read: if true;
      allow update: if (request.auth == null || isAdmin()) && request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['dispenserReports', 'status', 'officerSignature', 'clientSignature', 'clientRepName', 'officerSignatureDate', 'clientSignatureDate']);
    }

    // This rule allows the document owner OR an admin to perform any action on user subcollections.
     match /users/{userId}/{subcollection}/{docId} {
      allow read, write, create, update, delete: if isOwner(userId) || isAdmin();
    }
  }
}
