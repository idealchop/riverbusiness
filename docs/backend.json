
{
  "entities": {
    "AppUser": {
      "title": "AppUser",
      "type": "object",
      "description": "Represents a user of the River Business application.",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the user (matches Auth UID)." },
        "clientId": { "type": "string", "description": "Manually assigned client identifier." },
        "name": { "type": "string", "description": "User's full name." },
        "email": { "type": "string", "format": "email", "description": "User's login email address." },
        "businessEmail": { "type": "string", "format": "email", "description": "User's business contact email address." },
        "businessName": { "type": "string", "description": "User's business name." },
        "address": { "type": "string", "description": "User's address." },
        "contactNumber": { "type": "string", "description": "User's phone number." },
        "totalConsumptionLiters": { "type": "number" },
        "accountStatus": { "type": "string", "enum": ["Active", "Inactive"] },
        "lastLogin": { "type": "string", "format": "date-time" },
        "role": { "type": "string", "enum": ["Admin", "User"] },
        "hrRole": { "type": "string", "enum": ["owner", "admin", "employee"], "description": "Role within the HR module." },
        "companyId": { "type": "string", "description": "Tenant ID for multi-tenant isolation." },
        "assignedWaterStationId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "onboardingComplete": { "type": "boolean" },
        "plan": { "type": "object" },
        "customPlanDetails": { "type": "object" },
        "hrProfile": {
            "type": "object",
            "properties": {
                "firstName": { "type": "string" },
                "lastName": { "type": "string" },
                "salaryType": { "type": "string", "enum": ["daily", "monthly"] },
                "rate": { "type": "number" },
                "startDate": { "type": "string", "format": "date" },
                "position": { "type": "string" },
                "department": { "type": "string" },
                "status": { "type": "string", "enum": ["Active", "Terminated", "On Leave"] },
                "sssNumber": { "type": "string" },
                "philhealthNumber": { "type": "string" },
                "pagibigNumber": { "type": "string" },
                "tinNumber": { "type": "string" },
                "sssDeduction": { "type": "number" },
                "philhealthDeduction": { "type": "number" },
                "pagibigDeduction": { "type": "number" },
                "taxDeduction": { "type": "number" }
            }
        }
      },
      "required": ["id", "name", "email", "role", "createdAt"]
    },
    "HRAttendanceLog": {
        "title": "HRAttendanceLog",
        "type": "object",
        "properties": {
            "id": { "type": "string" },
            "companyId": { "type": "string" },
            "employeeId": { "type": "string" },
            "employeeName": { "type": "string" },
            "date": { "type": "string", "format": "date" },
            "timestamp": { "type": "string", "format": "date-time" },
            "action": { "type": "string", "enum": ["IN", "OUT"] },
            "gps_lat": { "type": "number" },
            "gps_long": { "type": "number" },
            "validation_status": { "type": "string", "enum": ["Valid", "Invalid"] },
            "method": { "type": "string", "enum": ["QR", "manual"] },
            "office_id": { "type": "string" }
        },
        "required": ["companyId", "employeeId", "date", "timestamp", "action"]
    },
    "HRCompanyLocation": {
        "title": "HRCompanyLocation",
        "type": "object",
        "properties": {
            "id": { "type": "string" },
            "companyId": { "type": "string" },
            "office_name": { "type": "string" },
            "latitude": { "type": "number" },
            "longitude": { "type": "number" },
            "radius_meters": { "type": "number" }
        },
        "required": ["companyId", "office_name", "latitude", "longitude"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/AppUser" },
      "description": "Stores user and employee profile information."
    },
    "/hr_companies/{companyId}/attendance/{logId}": {
        "schema": { "$ref": "#/entities/HRAttendanceLog" },
        "description": "Individual scan records for time in/out."
    },
    "/hr_companies/{companyId}/locations/{locationId}": {
        "schema": { "$ref": "#/entities/HRCompanyLocation" },
        "description": "Registered office locations for GPS validation."
    }
  }
}
