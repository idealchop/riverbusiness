{
  "entities": {
    "AppUser": {
      "title": "AppUser",
      "type": "object",
      "description": "Represents a user of the River Business application.",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the user (matches Auth UID)." },
        "clientId": { "type": "string", "description": "Manually assigned client identifier." },
        "name": { "type": "string", "description": "User's full name." },
        "email": { "type": "string", "format": "email", "description": "User's login email address." },
        "businessEmail": { "type": "string", "format": "email", "description": "User's business contact email address." },
        "businessName": { "type": "string", "description": "User's business name." },
        "address": { "type": "string", "description": "User's address." },
        "contactNumber": { "type": "string", "description": "User's phone number." },
        "totalConsumptionLiters": { "type": "number" },
        "accountStatus": { "type": "string", "enum": ["Active", "Inactive"] },
        "lastLogin": { "type": "string", "format": "date-time" },
        "role": { "type": "string", "enum": ["Admin", "User"] },
        "hrRole": { "type": "string", "enum": ["owner", "admin", "employee"], "description": "Role within the HR module." },
        "companyId": { "type": "string", "description": "Tenant ID for multi-tenant isolation." },
        "assignedWaterStationId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "onboardingComplete": { "type": "boolean" },
        "plan": { "type": "object" },
        "customPlanDetails": { "type": "object" },
        "hrProfile": {
            "type": "object",
            "properties": {
                "firstName": { "type": "string" },
                "lastName": { "type": "string" },
                "employeeNumber": { "type": "string", "description": "Unique auto-generated employee ID." },
                "salaryType": { "type": "string", "enum": ["daily", "weekly", "monthly", "bimonthly"] },
                "rate": { "type": "number" },
                "startDate": { "type": "string", "format": "date" },
                "position": { "type": "string" },
                "department": { "type": "string" }
            }
        }
      },
      "required": ["id", "name", "email", "role", "createdAt"]
    },
    "HRAttendanceLog": {
        "title": "HRAttendanceLog",
        "type": "object",
        "properties": {
            "id": { "type": "string" },
            "companyId": { "type": "string" },
            "employeeId": { "type": "string" },
            "employeeName": { "type": "string" },
            "date": { "type": "string", "format": "date" },
            "timeIn": { "type": "string", "format": "date-time" },
            "timeOut": { "type": "string", "format": "date-time" },
            "method": { "type": "string", "enum": ["QR", "manual"] },
            "status": { "type": "string", "enum": ["present", "late", "absent", "leave"] }
        },
        "required": ["companyId", "employeeId", "date", "timeIn"]
    },
    "HRLeaveRequest": {
        "title": "HRLeaveRequest",
        "type": "object",
        "properties": {
            "id": { "type": "string" },
            "companyId": { "type": "string" },
            "employeeId": { "type": "string" },
            "employeeName": { "type": "string" },
            "type": { "type": "string", "enum": ["Vacation", "Sick", "Emergency", "Maternity/Paternity"] },
            "startDate": { "type": "string", "format": "date" },
            "endDate": { "type": "string", "format": "date" },
            "reason": { "type": "string" },
            "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
            "appliedAt": { "type": "string", "format": "date-time" }
        },
        "required": ["companyId", "employeeId", "type", "startDate", "endDate", "status"]
    },
    "HRPayrollRun": {
        "title": "HRPayrollRun",
        "type": "object",
        "properties": {
            "id": { "type": "string" },
            "companyId": { "type": "string" },
            "periodStart": { "type": "string", "format": "date" },
            "periodEnd": { "type": "string", "format": "date" },
            "status": { "type": "string", "enum": ["draft", "processed", "paid"] },
            "totalNetSalary": { "type": "number" },
            "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": ["companyId", "periodStart", "periodEnd", "status"]
    },
    "HRLearningModule": {
        "title": "HRLearningModule",
        "type": "object",
        "properties": {
            "id": { "type": "string" },
            "companyId": { "type": "string" },
            "title": { "type": "string" },
            "description": { "type": "string" },
            "category": { "type": "string" },
            "contentType": { "type": "string", "enum": ["video", "image", "article"] },
            "contentUrl": { "type": "string" },
            "textContent": { "type": "string" },
            "createdAt": { "type": "string", "format": "date-time" },
            "isPublished": { "type": "boolean" }
        },
        "required": ["companyId", "title", "contentType"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/AppUser" },
      "description": "Stores user and employee profile information."
    },
    "/hr_companies/{companyId}/attendance/{logId}": {
        "schema": { "$ref": "#/entities/HRAttendanceLog" },
        "description": "Daily attendance logs for a company."
    },
    "/hr_companies/{companyId}/leaveRequests/{requestId}": {
        "schema": { "$ref": "#/entities/HRLeaveRequest" },
        "description": "Leave applications from employees."
    },
    "/hr_companies/{companyId}/payrollRuns/{runId}": {
        "schema": { "$ref": "#/entities/HRPayrollRun" },
        "description": "Historical records of payroll processing."
    },
    "/hr_companies/{companyId}/learningModules/{moduleId}": {
        "schema": { "$ref": "#/entities/HRLearningModule" },
        "description": "Company training and module materials."
    }
  }
}
