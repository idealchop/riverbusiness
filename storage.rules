rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // --- HELPER FUNCTIONS ---

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      // User is an admin if their custom claim 'admin' is true, or their email is the designated admin email.
      return request.auth.token.admin == true || request.auth.token.email == 'admin@riverph.com';
    }

    // --- SHARED CLOUD STORAGE ---
    // Allow public read to support shareable links and frictionless team collaboration.
    // Allow any authenticated user to write/upload to facilitate an open organizational drive.
    match /cloud_storage/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // --- FLEXIBLE ASSETS ---
    // Allow any authenticated user to manage profile photos, payment proofs, chat attachments, and collab images.
    // This removes strict individual ownership for a more flexible team environment.
    match /users/{allPaths=**} {
      allow read, write: if isAuthenticated();
    }
    match /chats/{allPaths=**} {
      allow read, write: if isAuthenticated();
    }
    
    // Aligned with Client ID and Organization
    match /collab_images/{companyId}/{allPaths=**} {
      allow read, write: if isAuthenticated();
    }
    
    // Legacy support for user-based paths if they still exist
    match /collab_images/{userId}/{allPaths=**} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // --- SECURE ADMINISTRATIVE ASSETS ---
    // Only admins can manage official station documents, contracts, and internal uploads.
    match /admin_uploads/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /userContracts/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /stations/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // --- PUBLIC MARKETING ASSETS ---
    match /Sales Portal/{allPaths=**} {
      allow read: if true;
    }
    match /River Mobile/{allPaths=**} {
      allow read: if true;
    }

    // Fallback rule: any authenticated user can read, only admins can write to root/other paths
    match /{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
